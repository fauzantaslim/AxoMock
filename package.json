{
  "name": "axomock",
  "version": "1.0.0",
  "description": "Mock your API in seconds. No backend needed. 🦎",
  "type": "module",
  "main": "src/server.js",
  "author": "Fauzan Taslim Hidayat",
  "scripts": {
    "start": "node src/server.js",
    "dev": "concurrently \"npm run watch:css\" \"nodemon src/server.js\"",
    "build:css": "npx tailwindcss -i ./src/css/input.css -o ./public/css/style.css --minify",
    "watch:css": "npx tailwindcss -i ./src/css/input.css -o ./public/css/style.css --watch",
    "lint": "npm run check-format && npm run check-lint",
    "check": "npm run lint",
    "check-format": "prettier --check .",
    "check-lint": "eslint .",
    "minify": "uglifyjs public/js/copy-code.js -o public/js/copy-code.min.js -c -m && uglifyjs public/js/docs.js -o public/js/docs.min.js -c -m",
    "prepare": "husky"
  },
  "keywords": [
    "mock",
    "api",
    "fake",
    "rest",
    "json",
    "testing",
    "development"
  ],
  "license": "MIT",
  "dependencies": {
    "alpinejs": "^3.15.12",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "node-cache": "^5.1.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "nodemon": "^3.1.4",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "tailwindcss": "^3.4.19",
    "uglify-js": "^3.19.3"
  }
}
