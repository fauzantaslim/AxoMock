<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — Axomock' : 'Axomock — Mock your API in seconds' %></title>
  <meta name="description" content="<%= typeof description !== 'undefined' ? description : 'Free fake REST API for testing and prototyping. Get realistic mock data for users, posts, comments, and todos. No setup required.' %>">
  <meta name="keywords" content="mock api, fake api, rest api, testing, prototyping, json server, mock data, frontend testing">
  <meta name="author" content="Fauzan Taslim Hidayat">
  <meta name="theme-color" content="#FF6B9D">

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://axomock.fauzantaslim.biz.id/">
  <meta property="og:title" content="<%= typeof title !== 'undefined' ? title + ' — Axomock' : 'Axomock — Mock your API in seconds' %>">
  <meta property="og:description" content="<%= typeof description !== 'undefined' ? description : 'Free fake REST API for testing and prototyping. No backend needed.' %>">
  <meta property="og:image" content="https://axomock.fauzantaslim.biz.id/images/axo1.png">

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:url" content="https://axomock.fauzantaslim.biz.id/">
  <meta name="twitter:title" content="<%= typeof title !== 'undefined' ? title + ' — Axomock' : 'Axomock — Mock your API in seconds' %>">
  <meta name="twitter:description" content="<%= typeof description !== 'undefined' ? description : 'Free fake REST API for testing and prototyping. No backend needed.' %>">
  <meta name="twitter:image" content="https://axomock.fauzantaslim.biz.id/images/axo1.png">

  <link rel="canonical" href="https://axomock.fauzantaslim.biz.id<%= typeof path !== 'undefined' ? path : '' %>">
  <link rel="icon" href="/images/head-axo.ico" type="image/x-icon">
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@600;700&display=swap" rel="stylesheet">
  
  <link rel="stylesheet" href="/css/style.css">
  <script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/collapse@3.x.x/dist/cdn.min.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head>
<body class="bg-white text-slate-700 font-sans antialiased min-h-screen flex flex-col">
  <%- include('../partials/header') %>

  <main class="flex-grow">
    <%- contentHtml %>
  </main>

  <%- include('../partials/footer') %>

  <% if (typeof scripts !== 'undefined' && scripts) { %>
    <% scripts.forEach(function(src) { %>
      <script src="<%= src %>"></script>
    <% }) %>
  <% } %>
  <script src="/js/copy-code.js"></script>
</body>
</html>
