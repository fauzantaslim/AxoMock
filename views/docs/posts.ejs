      axiosCode: `<span class="text-blue-400">axios</span>.<span class="text-blue-400">get</span>(<span class="text-emerald-400">'https://axomock.dev/api/posts?limit=10&skip=10'</span>)\n  .<span class="text-blue-400">then</span>(res => <span class="text-blue-400">console</span>.log(res.data));`,
      curlCode: `curl <span class="text-emerald-400">"https://axomock.dev/api/posts?limit=10&skip=10"</span>`,
      responseStatus: '200 OK',
      responseColor: 'bg-emerald-500',
      responseJson: `{\n  <span class="text-axolotl-pink-400">"posts"</span>: [\n    <span class="text-slate-500">...</span>\n  ],\n  <span class="text-axolotl-pink-400">"total"</span>: <span class="text-emerald-400">50</span>,\n  <span class="text-axolotl-pink-400">"skip"</span>: <span class="text-emerald-400">10</span>,\n  <span class="text-axolotl-pink-400">"limit"</span>: <span class="text-emerald-400">10</span>\n}`
