      curlCode: `curl -X DELETE <span class="text-emerald-400">https://axomock.dev/api/posts/1</span>`,
      responseStatus: '200 OK',
      responseColor: 'bg-emerald-500',
      responseJson: `{\n  <span class="text-axolotl-pink-400">"id"</span>: <span class="text-emerald-400">1</span>,\n  <span class="text-axolotl-pink-400">"title"</span>: <span class="text-emerald-400">"The future of web development in 2025"</span>,\n  <span class="text-slate-500">...</span>,\n  <span class="text-axolotl-pink-400">"isDeleted"</span>: <span class="text-axolotl-pink-400">true</span>,\n  <span class="text-axolotl-pink-400">"deletedOn"</span>: <span class="text-emerald-400">"2026-07-08T05:42:00.000Z"</span>\n}`
