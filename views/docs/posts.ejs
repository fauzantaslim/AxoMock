    <!-- PUT Update -->
    <%- include('../partials/api-endpoint', {
      id: 'update-post',
      title: 'Update a post',
      description: 'Updating a post will not update it into the server. It will simulate a PUT/PATCH request and will return the updated post.',
      fetchCode: `<span class="text-blue-400">fetch</span>(<span class="text-emerald-400">'https://axomock.dev/api/posts/1'</span>, {\n  method: <span class="text-emerald-400">'PUT'</span>, <span class="text-slate-500">/* or PATCH */</span>\n  headers: { <span class="text-emerald-400">'Content-Type'</span>: <span class="text-emerald-400">'application/json'</span> },\n  body: <span class="text-blue-400">JSON</span>.<span class="text-blue-400">stringify</span>({\n    title: <span class="text-emerald-400">'Updated post title'</span>\n  })\n})\n.<span class="text-blue-400">then</span>(res => res.<span class="text-blue-400">json</span>())\n.<span class="text-blue-400">then</span>(<span class="text-blue-400">console</span>.log);`,
      axiosCode: `<span class="text-blue-400">axios</span>.<span class="text-blue-400">put</span>(<span class="text-emerald-400">'https://axomock.dev/api/posts/1'</span>, {\n  title: <span class="text-emerald-400">'Updated post title'</span>\n})\n.<span class="text-blue-400">then</span>(res => <span class="text-blue-400">console</span>.log(res.data));`,
      curlCode: `curl -X PUT <span class="text-emerald-400">https://axomock.dev/api/posts/1</span> \\\n-H <span class="text-emerald-400">"Content-Type: application/json"</span> \\\n-d <span class="text-emerald-400">'{"title":"Updated post title"}'</span>`,
      responseStatus: '200 OK',
      responseColor: 'bg-emerald-500',
      responseJson: `{\n  <span class="text-axolotl-pink-400">"id"</span>: <span class="text-emerald-400">1</span>,\n  <span class="text-axolotl-pink-400">"title"</span>: <span class="text-emerald-400">"Updated post title"</span>,\n  <span class="text-slate-500">...</span>\n}`
    }) %>

