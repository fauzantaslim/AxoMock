      axiosCode: `<span class="text-blue-400">axios</span>.<span class="text-blue-400">get</span>(<span class="text-emerald-400">'https://axomock.dev/api/posts/search?q=react'</span>)\n  .<span class="text-blue-400">then</span>(res => <span class="text-blue-400">console</span>.log(res.data));`,
      curlCode: `curl <span class="text-emerald-400">"https://axomock.dev/api/posts/search?q=react"</span>`,
      responseStatus: '200 OK',
      responseColor: 'bg-emerald-500',
      responseJson: `{\n  <span class="text-axolotl-pink-400">"posts"</span>: [\n    {\n      <span class="text-axolotl-pink-400">"id"</span>: <span class="text-emerald-400">8</span>,\n      <span class="text-axolotl-pink-400">"title"</span>: <span class="text-emerald-400">"React hooks deep dive"</span>,\n      <span class="text-slate-500">...</span>\n    }\n  ],\n  <span class="text-axolotl-pink-400">"total"</span>: <span class="text-emerald-400">3</span>,\n  <span class="text-axolotl-pink-400">"skip"</span>: <span class="text-emerald-400">0</span>,\n  <span class="text-axolotl-pink-400">"limit"</span>: <span class="text-emerald-400">30</span>\n}`
    }) %>

