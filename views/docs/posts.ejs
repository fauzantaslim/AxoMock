<div class="flex flex-col md:flex-row max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-10 gap-8">
  <%- include('../partials/docs-sidebar', { activeSection: 'posts' }) %>
  
  <div class="flex-1 max-w-3xl min-w-0 pb-20">
    <h1 id="posts" class="text-3xl md:text-4xl font-display font-bold text-slate-950 mb-4 flex items-center gap-3">
      <img src="/images/posts.svg" alt="Posts" class="w-8 h-8 md:w-10 md:h-10 object-contain"> Posts API
    </h1>
    <p class="text-lg text-slate-600 mb-12 leading-relaxed">
      50 tech blog posts with tags and reactions.
    </p>

    <!-- GET All -->
    <%- include('../partials/api-endpoint', {
      id: 'get-all-posts',
      title: 'Get all posts',
      description: 'Get all posts (paginated).',
      fetchCode: `<span class="text-blue-400">fetch</span>(<span class="text-emerald-400">'https://axomock.dev/api/posts'</span>)\n  .<span class="text-blue-400">then</span>(res => res.<span class="text-blue-400">json</span>())\n  .<span class="text-blue-400">then</span>(<span class="text-blue-400">console</span>.log);`,
      axiosCode: `<span class="text-blue-400">axios</span>.<span class="text-blue-400">get</span>(<span class="text-emerald-400">'https://axomock.dev/api/posts'</span>)\n  .<span class="text-blue-400">then</span>(res => <span class="text-blue-400">console</span>.log(res.data));`,
      curlCode: `curl <span class="text-emerald-400">https://axomock.dev/api/posts</span>`,
      responseStatus: '200 OK',
      responseColor: 'bg-emerald-500',
      responseJson: `{\n  <span class="text-axolotl-pink-400">"posts"</span>: [\n    {\n      <span class="text-axolotl-pink-400">"id"</span>: <span class="text-emerald-400">1</span>,\n      <span class="text-axolotl-pink-400">"title"</span>: <span class="text-emerald-400">"The future of web development in 2025"</span>,\n      <span class="text-axolotl-pink-400">"body"</span>: <span class="text-emerald-400">"Web development continues to evolve at a rapid pace..."</span>,\n      <span class="text-axolotl-pink-400">"userId"</span>: <span class="text-emerald-400">1</span>,\n      <span class="text-axolotl-pink-400">"tags"</span>: [\n        <span class="text-emerald-400">"webdev"</span>,\n        <span class="text-emerald-400">"javascript"</span>,\n        <span class="text-emerald-400">"frontend"</span>\n      ],\n      <span class="text-axolotl-pink-400">"reactions"</span>: {\n        <span class="text-axolotl-pink-400">"likes"</span>: <span class="text-emerald-400">142</span>,\n        <span class="text-axolotl-pink-400">"dislikes"</span>: <span class="text-emerald-400">7</span>\n      }\n    },\n    <span class="text-slate-500">... // 29 more items</span>\n  ],\n  <span class="text-axolotl-pink-400">"total"</span>: <span class="text-emerald-400">50</span>,\n  <span class="text-axolotl-pink-400">"skip"</span>: <span class="text-emerald-400">0</span>,\n  <span class="text-axolotl-pink-400">"limit"</span>: <span class="text-emerald-400">30</span>\n}`
    }) %>
    
    <hr class="border-slate-200 my-12">

    <!-- GET Single -->
