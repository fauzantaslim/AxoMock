    }) %>

    <hr class="border-slate-200 my-12">

    <!-- POST Create -->
    <%- include('../partials/api-endpoint', {
      id: 'create-post',
      title: 'Create a post',
      description: 'Adding a new post will not add it into the server. It will simulate a POST request and will return the new created post with a new id.',
      fetchCode: `<span class="text-blue-400">fetch</span>(<span class="text-emerald-400">'https://axomock.dev/api/posts/add'</span>, {\n  method: <span class="text-emerald-400">'POST'</span>,\n  headers: { <span class="text-emerald-400">'Content-Type'</span>: <span class="text-emerald-400">'application/json'</span> },\n  body: <span class="text-blue-400">JSON</span>.<span class="text-blue-400">stringify</span>({\n    title: <span class="text-emerald-400">'New post title'</span>,\n    body: <span class="text-emerald-400">'This is the body of the new post'</span>,\n    userId: <span class="text-emerald-400">5</span>\n  })\n})\n.<span class="text-blue-400">then</span>(res => res.<span class="text-blue-400">json</span>())\n.<span class="text-blue-400">then</span>(<span class="text-blue-400">console</span>.log);`,
      axiosCode: `<span class="text-blue-400">axios</span>.<span class="text-blue-400">post</span>(<span class="text-emerald-400">'https://axomock.dev/api/posts/add'</span>, {\n  title: <span class="text-emerald-400">'New post title'</span>,\n  body: <span class="text-emerald-400">'This is the body of the new post'</span>,\n  userId: <span class="text-emerald-400">5</span>\n})\n.<span class="text-blue-400">then</span>(res => <span class="text-blue-400">console</span>.log(res.data));`,
      curlCode: `curl -X POST <span class="text-emerald-400">https://axomock.dev/api/posts/add</span> \\\n-H <span class="text-emerald-400">"Content-Type: application/json"</span> \\\n-d <span class="text-emerald-400">'{"title":"New post title","body":"This is the body of the new post","userId":5}'</span>`,
      responseStatus: '201 Created',
      responseColor: 'bg-emerald-500',
      responseJson: `{\n  <span class="text-axolotl-pink-400">"id"</span>: <span class="text-emerald-400">51</span>,\n  <span class="text-axolotl-pink-400">"title"</span>: <span class="text-emerald-400">"New post title"</span>,\n  <span class="text-axolotl-pink-400">"body"</span>: <span class="text-emerald-400">"This is the body of the new post"</span>,\n  <span class="text-axolotl-pink-400">"userId"</span>: <span class="text-emerald-400">5</span>,\n  <span class="text-axolotl-pink-400">"tags"</span>: [],\n  <span class="text-axolotl-pink-400">"reactions"</span>: {\n    <span class="text-axolotl-pink-400">"likes"</span>: <span class="text-emerald-400">0</span>,\n    <span class="text-axolotl-pink-400">"dislikes"</span>: <span class="text-emerald-400">0</span>\n  }\n}`
    }) %>

