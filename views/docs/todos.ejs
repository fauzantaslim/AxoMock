<div class="flex flex-col md:flex-row max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-10 gap-8">
  <%- include('../partials/docs-sidebar', { activeSection: 'todos' }) %>
  
  <div class="flex-1 max-w-3xl min-w-0 pb-20">
    <h1 id="todos" class="text-3xl md:text-4xl font-display font-bold text-slate-950 mb-4 flex items-center gap-3">
      <img src="/images/todos.svg" alt="Todos" class="w-8 h-8 md:w-10 md:h-10 object-contain"> Todos API
    </h1>
    <p class="text-lg text-slate-600 mb-12 leading-relaxed">
      50 developer-themed todos.
    </p>

    <!-- GET All -->
    <%- include('../partials/api-endpoint', {
      id: 'get-all-todos',
      title: 'Get all todos',
      description: 'Get all todos (paginated).',
      fetchCode: `<span class="text-blue-400">fetch</span>(<span class="text-emerald-400">'https://axomock.fauzantaslim.biz.id/api/todos'</span>)\n  .<span class="text-blue-400">then</span>(res => res.<span class="text-blue-400">json</span>())\n  .<span class="text-blue-400">then</span>(<span class="text-blue-400">console</span>.log);`,
      axiosCode: `<span class="text-blue-400">axios</span>.<span class="text-blue-400">get</span>(<span class="text-emerald-400">'https://axomock.fauzantaslim.biz.id/api/todos'</span>)\n  .<span class="text-blue-400">then</span>(res => <span class="text-blue-400">console</span>.log(res.data));`,
      curlCode: `curl <span class="text-emerald-400">https://axomock.fauzantaslim.biz.id/api/todos</span>`,
      responseStatus: '200 OK',
      responseColor: 'bg-emerald-500',
      responseJson: `{\n  <span class="text-axolotl-pink-400">"todos"</span>: [\n    {\n      <span class="text-axolotl-pink-400">"id"</span>: <span class="text-emerald-400">1</span>,\n      <span class="text-axolotl-pink-400">"todo"</span>: <span class="text-emerald-400">"Complete the project proposal document"</span>,\n      <span class="text-axolotl-pink-400">"completed"</span>: <span class="text-axolotl-pink-400">false</span>,\n      <span class="text-axolotl-pink-400">"userId"</span>: <span class="text-emerald-400">1</span>\n    },\n    <span class="text-slate-500">... // 29 more items</span>\n  ],\n  <span class="text-axolotl-pink-400">"total"</span>: <span class="text-emerald-400">50</span>,\n  <span class="text-axolotl-pink-400">"skip"</span>: <span class="text-emerald-400">0</span>,\n  <span class="text-axolotl-pink-400">"limit"</span>: <span class="text-emerald-400">30</span>\n}`
    }) %>
    
    <hr class="border-slate-200 my-12">

    <!-- GET Single -->
    <%- include('../partials/api-endpoint', {
      id: 'get-single-todo',
      title: 'Get a single todo',
      description: 'Get a single todo by ID.',
      fetchCode: `<span class="text-blue-400">fetch</span>(<span class="text-emerald-400">'https://axomock.fauzantaslim.biz.id/api/todos/1'</span>)\n  .<span class="text-blue-400">then</span>(res => res.<span class="text-blue-400">json</span>())\n  .<span class="text-blue-400">then</span>(<span class="text-blue-400">console</span>.log);`,
      axiosCode: `<span class="text-blue-400">axios</span>.<span class="text-blue-400">get</span>(<span class="text-emerald-400">'https://axomock.fauzantaslim.biz.id/api/todos/1'</span>)\n  .<span class="text-blue-400">then</span>(res => <span class="text-blue-400">console</span>.log(res.data));`,
      curlCode: `curl <span class="text-emerald-400">https://axomock.fauzantaslim.biz.id/api/todos/1</span>`,
      responseStatus: '200 OK',
      responseColor: 'bg-emerald-500',
      responseJson: `{\n  <span class="text-axolotl-pink-400">"id"</span>: <span class="text-emerald-400">1</span>,\n  <span class="text-axolotl-pink-400">"todo"</span>: <span class="text-emerald-400">"Complete the project proposal document"</span>,\n  <span class="text-axolotl-pink-400">"completed"</span>: <span class="text-axolotl-pink-400">false</span>,\n  <span class="text-axolotl-pink-400">"userId"</span>: <span class="text-emerald-400">1</span>\n}`
    }) %>

    <hr class="border-slate-200 my-12">

    <!-- GET Search -->
    <%- include('../partials/api-endpoint', {
      id: 'search-todos',
      title: 'Search todos',
      description: 'Search todos by task content.',
      fetchCode: `<span class="text-blue-400">fetch</span>(<span class="text-emerald-400">'https://axomock.fauzantaslim.biz.id/api/todos/search?q=project'</span>)\n  .<span class="text-blue-400">then</span>(res => res.<span class="text-blue-400">json</span>())\n  .<span class="text-blue-400">then</span>(<span class="text-blue-400">console</span>.log);`,
      axiosCode: `<span class="text-blue-400">axios</span>.<span class="text-blue-400">get</span>(<span class="text-emerald-400">'https://axomock.fauzantaslim.biz.id/api/todos/search?q=project'</span>)\n  .<span class="text-blue-400">then</span>(res => <span class="text-blue-400">console</span>.log(res.data));`,
      curlCode: `curl <span class="text-emerald-400">"https://axomock.fauzantaslim.biz.id/api/todos/search?q=project"</span>`,
      responseStatus: '200 OK',
      responseColor: 'bg-emerald-500',
      responseJson: `{\n  <span class="text-axolotl-pink-400">"todos"</span>: [\n    <span class="text-slate-500">... // array of matched todos</span>\n  ],\n  <span class="text-axolotl-pink-400">"total"</span>: <span class="text-emerald-400">3</span>,\n  <span class="text-axolotl-pink-400">"skip"</span>: <span class="text-emerald-400">0</span>,\n  <span class="text-axolotl-pink-400">"limit"</span>: <span class="text-emerald-400">30</span>\n}`
    }) %>

    <hr class="border-slate-200 my-12">

    <!-- GET Random -->
    <%- include('../partials/api-endpoint', {
      id: 'get-random-todo',
      title: 'Get a random todo',
      description: 'Get a random todo item.',
      fetchCode: `<span class="text-blue-400">fetch</span>(<span class="text-emerald-400">'https://axomock.fauzantaslim.biz.id/api/todos/random'</span>)\n  .<span class="text-blue-400">then</span>(res => res.<span class="text-blue-400">json</span>())\n  .<span class="text-blue-400">then</span>(<span class="text-blue-400">console</span>.log);`,
      axiosCode: `<span class="text-blue-400">axios</span>.<span class="text-blue-400">get</span>(<span class="text-emerald-400">'https://axomock.fauzantaslim.biz.id/api/todos/random'</span>)\n  .<span class="text-blue-400">then</span>(res => <span class="text-blue-400">console</span>.log(res.data));`,
      curlCode: `curl <span class="text-emerald-400">https://axomock.fauzantaslim.biz.id/api/todos/random</span>`,
      responseStatus: '200 OK',
      responseColor: 'bg-emerald-500',
      responseJson: `{\n  <span class="text-axolotl-pink-400">"id"</span>: <span class="text-emerald-400">14</span>,\n  <span class="text-axolotl-pink-400">"todo"</span>: <span class="text-emerald-400">"Set up staging environment"</span>,\n  <span class="text-axolotl-pink-400">"completed"</span>: <span class="text-axolotl-pink-400">true</span>,\n  <span class="text-axolotl-pink-400">"userId"</span>: <span class="text-emerald-400">7</span>\n}`
    }) %>

    <hr class="border-slate-200 my-12">

    <!-- GET Limit and Skip -->
    <%- include('../partials/api-endpoint', {
      id: 'limit-and-skip-todos',
      title: 'Limit and skip todos',
      description: 'You can pass <code class="bg-slate-100 text-axolotl-pink-600 px-1.5 py-0.5 rounded font-mono text-sm">limit</code> and <code class="bg-slate-100 text-axolotl-pink-600 px-1.5 py-0.5 rounded font-mono text-sm">skip</code> params to limit and skip the results for pagination.',
      fetchCode: `<span class="text-blue-400">fetch</span>(<span class="text-emerald-400">'https://axomock.fauzantaslim.biz.id/api/todos?limit=10&skip=10'</span>)\n  .<span class="text-blue-400">then</span>(res => res.<span class="text-blue-400">json</span>())\n  .<span class="text-blue-400">then</span>(<span class="text-blue-400">console</span>.log);`,
      axiosCode: `<span class="text-blue-400">axios</span>.<span class="text-blue-400">get</span>(<span class="text-emerald-400">'https://axomock.fauzantaslim.biz.id/api/todos?limit=10&skip=10'</span>)\n  .<span class="text-blue-400">then</span>(res => <span class="text-blue-400">console</span>.log(res.data));`,
      curlCode: `curl <span class="text-emerald-400">"https://axomock.fauzantaslim.biz.id/api/todos?limit=10&skip=10"</span>`,
      responseStatus: '200 OK',
      responseColor: 'bg-emerald-500',
      responseJson: `{\n  <span class="text-axolotl-pink-400">"todos"</span>: [\n    <span class="text-slate-500">...</span>\n  ],\n  <span class="text-axolotl-pink-400">"total"</span>: <span class="text-emerald-400">50</span>,\n  <span class="text-axolotl-pink-400">"skip"</span>: <span class="text-emerald-400">10</span>,\n  <span class="text-axolotl-pink-400">"limit"</span>: <span class="text-emerald-400">10</span>\n}`
    }) %>

    <hr class="border-slate-200 my-12">

    <!-- POST Create -->
    <%- include('../partials/api-endpoint', {
      id: 'create-todo',
      title: 'Create a todo',
      description: 'Adding a new todo will not add it into the server. It will simulate a POST request and will return the new created todo with a new id.',
      fetchCode: `<span class="text-blue-400">fetch</span>(<span class="text-emerald-400">'https://axomock.fauzantaslim.biz.id/api/todos/add'</span>, {\n  method: <span class="text-emerald-400">'POST'</span>,\n  headers: { <span class="text-emerald-400">'Content-Type'</span>: <span class="text-emerald-400">'application/json'</span> },\n  body: <span class="text-blue-400">JSON</span>.<span class="text-blue-400">stringify</span>({\n    todo: <span class="text-emerald-400">'Learn Next.js 14'</span>,\n    completed: <span class="text-axolotl-pink-400">false</span>,\n    userId: <span class="text-emerald-400">5</span>\n  })\n})\n.<span class="text-blue-400">then</span>(res => res.<span class="text-blue-400">json</span>())\n.<span class="text-blue-400">then</span>(<span class="text-blue-400">console</span>.log);`,
      axiosCode: `<span class="text-blue-400">axios</span>.<span class="text-blue-400">post</span>(<span class="text-emerald-400">'https://axomock.fauzantaslim.biz.id/api/todos/add'</span>, {\n  todo: <span class="text-emerald-400">'Learn Next.js 14'</span>,\n  completed: <span class="text-axolotl-pink-400">false</span>,\n  userId: <span class="text-emerald-400">5</span>\n})\n.<span class="text-blue-400">then</span>(res => <span class="text-blue-400">console</span>.log(res.data));`,
      curlCode: `curl -X POST <span class="text-emerald-400">https://axomock.fauzantaslim.biz.id/api/todos/add</span> \\\n-H <span class="text-emerald-400">"Content-Type: application/json"</span> \\\n-d <span class="text-emerald-400">'{"todo":"Learn Next.js 14","completed":false,"userId":5}'</span>`,
      responseStatus: '201 Created',
      responseColor: 'bg-emerald-500',
      responseJson: `{\n  <span class="text-axolotl-pink-400">"id"</span>: <span class="text-emerald-400">51</span>,\n  <span class="text-axolotl-pink-400">"todo"</span>: <span class="text-emerald-400">"Learn Next.js 14"</span>,\n  <span class="text-axolotl-pink-400">"completed"</span>: <span class="text-axolotl-pink-400">false</span>,\n  <span class="text-axolotl-pink-400">"userId"</span>: <span class="text-emerald-400">5</span>\n}`
    }) %>

    <hr class="border-slate-200 my-12">

    <!-- PUT Update -->
    <%- include('../partials/api-endpoint', {
      id: 'update-todo',
      title: 'Update a todo',
      description: 'Updating a todo will not update it into the server. It will simulate a PUT/PATCH request and will return the updated todo.',
      fetchCode: `<span class="text-blue-400">fetch</span>(<span class="text-emerald-400">'https://axomock.fauzantaslim.biz.id/api/todos/1'</span>, {\n  method: <span class="text-emerald-400">'PUT'</span>, <span class="text-slate-500">/* or PATCH */</span>\n  headers: { <span class="text-emerald-400">'Content-Type'</span>: <span class="text-emerald-400">'application/json'</span> },\n  body: <span class="text-blue-400">JSON</span>.<span class="text-blue-400">stringify</span>({\n    completed: <span class="text-axolotl-pink-400">true</span>\n  })\n})\n.<span class="text-blue-400">then</span>(res => res.<span class="text-blue-400">json</span>())\n.<span class="text-blue-400">then</span>(<span class="text-blue-400">console</span>.log);`,
      axiosCode: `<span class="text-blue-400">axios</span>.<span class="text-blue-400">put</span>(<span class="text-emerald-400">'https://axomock.fauzantaslim.biz.id/api/todos/1'</span>, {\n  completed: <span class="text-axolotl-pink-400">true</span>\n})\n.<span class="text-blue-400">then</span>(res => <span class="text-blue-400">console</span>.log(res.data));`,
      curlCode: `curl -X PUT <span class="text-emerald-400">https://axomock.fauzantaslim.biz.id/api/todos/1</span> \\\n-H <span class="text-emerald-400">"Content-Type: application/json"</span> \\\n-d <span class="text-emerald-400">'{"completed":true}'</span>`,
      responseStatus: '200 OK',
      responseColor: 'bg-emerald-500',
      responseJson: `{\n  <span class="text-axolotl-pink-400">"id"</span>: <span class="text-emerald-400">1</span>,\n  <span class="text-axolotl-pink-400">"todo"</span>: <span class="text-emerald-400">"Complete the project proposal document"</span>,\n  <span class="text-axolotl-pink-400">"completed"</span>: <span class="text-axolotl-pink-400">true</span>,\n  <span class="text-slate-500">...</span>\n}`
    }) %>

    <hr class="border-slate-200 my-12">

    <!-- DELETE Delete -->
    <%- include('../partials/api-endpoint', {
      id: 'delete-todo',
      title: 'Delete a todo',
      description: 'Deleting a todo will not delete it into the server. It will simulate a DELETE request and will return deleted todo.',
      fetchCode: `<span class="text-blue-400">fetch</span>(<span class="text-emerald-400">'https://axomock.fauzantaslim.biz.id/api/todos/1'</span>, {\n  method: <span class="text-emerald-400">'DELETE'</span>,\n})\n.<span class="text-blue-400">then</span>(res => res.<span class="text-blue-400">json</span>())\n.<span class="text-blue-400">then</span>(<span class="text-blue-400">console</span>.log);`,
      axiosCode: `<span class="text-blue-400">axios</span>.<span class="text-blue-400">delete</span>(<span class="text-emerald-400">'https://axomock.fauzantaslim.biz.id/api/todos/1'</span>)\n.<span class="text-blue-400">then</span>(res => <span class="text-blue-400">console</span>.log(res.data));`,
      curlCode: `curl -X DELETE <span class="text-emerald-400">https://axomock.fauzantaslim.biz.id/api/todos/1</span>`,
      responseStatus: '200 OK',
      responseColor: 'bg-emerald-500',
      responseJson: `{\n  <span class="text-axolotl-pink-400">"id"</span>: <span class="text-emerald-400">1</span>,\n  <span class="text-axolotl-pink-400">"todo"</span>: <span class="text-emerald-400">"Complete the project proposal document"</span>,\n  <span class="text-slate-500">...</span>,\n  <span class="text-axolotl-pink-400">"isDeleted"</span>: <span class="text-axolotl-pink-400">true</span>,\n  <span class="text-axolotl-pink-400">"deletedOn"</span>: <span class="text-emerald-400">"2026-07-08T05:42:00.000Z"</span>\n}`
    }) %>

  </div>
</div>
