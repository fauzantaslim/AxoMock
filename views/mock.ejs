<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16" x-data="mockBuilder()" x-init="init()">

  <!-- Page Header -->
  <div class="mb-12">
    <p class="text-xs font-mono font-semibold tracking-widest text-axolotl-pink-500 uppercase mb-3">Mock Builder</p>
    <h1 class="text-4xl lg:text-5xl font-display font-bold text-slate-950 mb-4">Your personal mock API.</h1>
    <p class="text-lg text-slate-600 max-w-2xl leading-relaxed">
      Create custom endpoints with any HTTP method and JSON response body. No account needed — mock data is kept for your session.
    </p>
  </div>

  <!-- Session Info Banner -->
  <div class="mb-10 flex flex-col sm:flex-row sm:items-center gap-3 p-4 bg-slate-50 border border-slate-200 rounded-xl">
    <div class="flex items-center gap-2 flex-1 min-w-0">
      <svg class="w-4 h-4 text-slate-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path></svg>
      <span class="text-xs font-mono text-slate-500 truncate">Session: <span class="text-slate-800" x-text="sessionId"></span></span>
    </div>
    <div class="flex items-center gap-2">
      <div class="w-2 h-2 rounded-full bg-green-400"></div>
      <span class="text-xs text-slate-500"><span x-text="mocks.length"></span> / 10 mocks used</span>
    </div>
  </div>

  <!-- Main Split Layout -->
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">

    <!-- Left: Create Mock Form (2/5 width) -->
    <div class="lg:col-span-2">
      <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-[0_4px_6px_rgba(0,0,0,0.04)]">
        <div class="px-6 py-5 border-b border-slate-100">
          <h2 class="text-base font-display font-bold text-slate-950">Create endpoint</h2>
          <p class="text-sm text-slate-500 mt-0.5">Define your mock request and response.</p>
        </div>

        <form @submit.prevent="createMock" class="p-6 space-y-5">

          <!-- Method + Path -->
          <div>
            <label class="block text-xs font-semibold text-slate-700 uppercase tracking-wide mb-2">Method & Path</label>
            <div class="flex gap-2">
              <!-- Method Dropdown -->
              <select x-model="form.method" class="cursor-pointer flex-shrink-0 px-3 py-2.5 text-sm font-mono font-bold rounded-lg border border-slate-200 bg-slate-50 focus:outline-none focus:ring-2 focus:ring-axolotl-pink-500/30 focus:border-axolotl-pink-500 transition-colors"
                :class="{
                  'text-deep-teal': form.method === 'GET',
                  'text-green-600': form.method === 'POST',
                  'text-blue-600': form.method === 'PUT',
                  'text-amber-600': form.method === 'PATCH',
                  'text-red-600': form.method === 'DELETE'
                }">
                <option value="GET">GET</option>
                <option value="POST">POST</option>
                <option value="PUT">PUT</option>
                <option value="PATCH">PATCH</option>
                <option value="DELETE">DELETE</option>
              </select>
              <!-- Path Input -->
              <div class="flex-1 relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm font-mono pointer-events-none">/mock/…/</span>
                <input
                  x-model="form.path"
                  type="text"
                  placeholder="products/featured"
                  class="w-full pl-[72px] pr-3 py-2.5 text-sm font-mono rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-axolotl-pink-500/30 focus:border-axolotl-pink-500 transition-colors placeholder:text-slate-400"
                  :class="{ 'border-red-400': errors.path }"
                >
              </div>
            </div>
            <p x-show="errors.path" x-text="errors.path" class="mt-1.5 text-xs text-red-500"></p>
          </div>

          <!-- Response Body -->
          <div>
            <div class="flex items-center justify-between mb-2">
              <label class="block text-xs font-semibold text-slate-700 uppercase tracking-wide">Response Body (JSON)</label>
              <button type="button" @click="formatJson" class="cursor-pointer text-xs text-deep-teal hover:underline">Format</button>
            </div>
            <textarea
              x-model="form.responseBody"
              rows="10"
              placeholder='{\n  "status": "ok",\n  "data": []\n}'
              class="w-full px-4 py-3 text-sm font-mono rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-axolotl-pink-500/30 focus:border-axolotl-pink-500 transition-colors resize-none placeholder:text-slate-400 leading-relaxed"
              :class="{ 'border-red-400': errors.responseBody }"
            ></textarea>
            <p x-show="errors.responseBody" x-text="errors.responseBody" class="mt-1.5 text-xs text-red-500"></p>
          </div>

          <!-- API Error -->
          <div x-show="apiError" class="p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-600" x-text="apiError"></div>

          <!-- Submit Button -->
          <button
            type="submit"
            :disabled="mocks.length >= 10 || loading"
            class="w-full cursor-pointer inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-bold text-white bg-axolotl-pink-500 hover:bg-[#F0447D] disabled:bg-slate-300 disabled:cursor-not-allowed rounded-lg transition-colors"
          >
            <svg x-show="!loading" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            <svg x-show="loading" class="w-4 h-4 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
            <span x-text="mocks.length >= 10 ? 'Limit reached (10/10)' : (loading ? 'Creating…' : 'Create Mock')"></span>
          </button>

        </form>
      </div>
    </div>

    <!-- Right: Active Mocks List (3/5 width) -->
    <div class="lg:col-span-3">
      <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-[0_4px_6px_rgba(0,0,0,0.04)]">
        <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between">
          <div>
            <h2 class="text-base font-display font-bold text-slate-950">Active mocks</h2>
            <p class="text-sm text-slate-500 mt-0.5">Call these endpoints from your frontend.</p>
          </div>
          <span class="text-xs font-mono text-slate-400 bg-slate-100 px-2.5 py-1 rounded-full" x-text="`${mocks.length} / 10`"></span>
        </div>

        <!-- Empty State -->
        <div x-show="mocks.length === 0" class="flex flex-col items-center justify-center py-20 px-6 text-center">
          <div class="w-14 h-14 bg-slate-100 rounded-2xl flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          </div>
          <p class="text-slate-700 font-semibold mb-1">No mocks yet</p>
          <p class="text-sm text-slate-500 max-w-xs">Create your first endpoint using the form on the left. It'll appear here instantly.</p>
        </div>

        <!-- Mocks List -->
        <ul x-show="mocks.length > 0" class="divide-y divide-slate-100">
          <template x-for="mock in mocks" :key="mock.mockId">
            <li class="px-6 py-4 flex items-start gap-4 group">
              <!-- Method Badge -->
              <span
                class="flex-shrink-0 mt-0.5 inline-flex items-center px-2 py-0.5 rounded text-xs font-mono font-bold"
                :class="{
                  'bg-teal-50 text-teal-700': mock.method === 'GET',
                  'bg-green-50 text-green-700': mock.method === 'POST',
                  'bg-blue-50 text-blue-700': mock.method === 'PUT',
                  'bg-amber-50 text-amber-700': mock.method === 'PATCH',
                  'bg-red-50 text-red-700': mock.method === 'DELETE'
                }"
                x-text="mock.method"
              ></span>

              <!-- URL & Copy -->
              <div class="flex-1 min-w-0">
                <div
                  x-data="{ copied: false }"
                  @click="
                    navigator.clipboard.writeText(window.location.origin + mock.url);
                    copied = true;
                    setTimeout(() => copied = false, 2000);
                  "
                  class="cursor-pointer group/copy flex items-center gap-2"
                  title="Click to copy full URL"
                >
                  <span class="text-sm font-mono text-slate-700 truncate group-hover/copy:text-axolotl-pink-500 transition-colors" x-text="mock.url"></span>
                  <svg x-show="!copied" class="w-3.5 h-3.5 flex-shrink-0 text-slate-300 group-hover/copy:text-axolotl-pink-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                  <svg x-show="copied" x-cloak class="w-3.5 h-3.5 flex-shrink-0 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                </div>
                <!-- Response preview -->
                <p class="text-xs text-slate-400 font-mono mt-1 truncate" x-text="JSON.stringify(mock.responseBody).substring(0, 60) + (JSON.stringify(mock.responseBody).length > 60 ? '…' : '')"></p>
              </div>

              <!-- Delete Button -->
              <button
                @click="deleteMock(mock.mockId)"
                class="cursor-pointer flex-shrink-0 mt-0.5 p-1.5 rounded-md text-slate-300 hover:text-red-500 hover:bg-red-50 transition-colors opacity-0 group-hover:opacity-100"
                title="Delete mock"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
              </button>
            </li>
          </template>
        </ul>

      </div>

      <!-- Usage Guide -->
      <div class="mt-6 bg-slate-950 rounded-2xl overflow-hidden border border-slate-800">
        <div class="px-5 py-3.5 border-b border-slate-800 flex items-center justify-between">
          <span class="text-xs font-mono text-slate-400">How to use your mock</span>
          <div class="flex gap-1.5">
            <div class="w-2.5 h-2.5 rounded-full bg-slate-700"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-slate-700"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-slate-700"></div>
          </div>
        </div>
        <div class="p-5">
          <pre class="text-sm font-mono leading-relaxed text-slate-300 overflow-x-auto whitespace-pre"><code><span class="text-slate-500">// After creating a mock, call it directly from your app:</span>
<span class="text-axolotl-pink-400">const</span> res = <span class="text-blue-400">await</span> <span class="text-axolotl-pink-400">fetch</span>(<span x-text="'`' + window.location.origin + '/mock/' + sessionId + '/your-path`'"></span>);
<span class="text-axolotl-pink-400">const</span> data = <span class="text-blue-400">await</span> res.<span class="text-axolotl-pink-400">json</span>();
<span class="text-slate-500">// → returns your configured JSON response</span></code></pre>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
function mockBuilder() {
  return {
    sessionId: '',
    mocks: [],
    loading: false,
    apiError: '',
    form: {
      method: 'GET',
      path: '',
      responseBody: '{\n  "status": "ok",\n  "data": []\n}',
    },
    errors: {
      path: '',
      responseBody: '',
    },

    init() {
      // Get or generate session ID
      let id = localStorage.getItem('axomock_session_id');
      if (!id) {
        id = crypto.randomUUID();
        localStorage.setItem('axomock_session_id', id);
      }
      this.sessionId = id;
      this.fetchMocks();
    },

    async fetchMocks() {
      try {
        const res = await fetch(`/api/mock/${this.sessionId}`);
        const data = await res.json();
        this.mocks = data.mocks || [];
      } catch (e) {
        // Silently ignore if session doesn't exist yet
        this.mocks = [];
      }
    },

    formatJson() {
      try {
        const parsed = JSON.parse(this.form.responseBody);
        this.form.responseBody = JSON.stringify(parsed, null, 2);
        this.errors.responseBody = '';
      } catch (e) {
        this.errors.responseBody = 'Invalid JSON — cannot format';
      }
    },

    validate() {
      this.errors.path = '';
      this.errors.responseBody = '';
      let valid = true;

      const path = this.form.path.trim();
      if (!path) {
        this.errors.path = 'Path is required';
        valid = false;
      } else if (!/^[a-zA-Z0-9_\-/]+$/.test(path.replace(/^\/+/, ''))) {
        this.errors.path = 'Only letters, numbers, dashes, underscores, and slashes allowed';
        valid = false;
      }

      try {
        JSON.parse(this.form.responseBody);
      } catch (e) {
        this.errors.responseBody = 'Response body must be valid JSON';
        valid = false;
      }

      return valid;
    },

    async createMock() {
      this.apiError = '';
      if (!this.validate()) return;

      this.loading = true;
      try {
        const res = await fetch('/api/mock', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            sessionId: this.sessionId,
            method: this.form.method,
            path: this.form.path.trim().replace(/^\/+/, ''),
            responseBody: JSON.parse(this.form.responseBody),
          }),
        });

        const data = await res.json();

        if (!res.ok) {
          this.apiError = data.message || 'Failed to create mock';
          return;
        }

        this.mocks.unshift(data);
        // Reset form path only, keep method and body for quick iteration
        this.form.path = '';
      } catch (e) {
        this.apiError = 'Network error — please try again';
      } finally {
        this.loading = false;
      }
    },

    async deleteMock(mockId) {
      try {
        const res = await fetch(`/api/mock/${this.sessionId}/${mockId}`, {
          method: 'DELETE',
        });
        if (res.ok) {
          this.mocks = this.mocks.filter((m) => m.mockId !== mockId);
        }
      } catch (e) {
        // Silent fail — the UI will remain unchanged
      }
    },
  };
}
</script>
