<header 
  x-data="{ mobileMenuOpen: false }" 
  class="sticky top-0 z-40 w-full backdrop-blur-md bg-white/80 border-b border-slate-200"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <img src="/images/head-axo.png" alt="Axomock" class="w-8 h-8 transition-transform group-hover:scale-110 object-contain">
        <span class="font-display font-bold text-xl text-slate-950 tracking-tight">Axomock</span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-8">
        <% 
          const isHome = typeof page !== 'undefined' && page === 'home';
          const isDocs = typeof page !== 'undefined' && page === 'docs';
          const isMock = typeof page !== 'undefined' && page === 'mock';
        %>
        <a href="/" class="relative px-1 py-2 text-sm font-medium transition-colors group <%= isHome ? 'text-axolotl-pink-500' : 'text-slate-600 hover:text-slate-950' %>">
          Home
          <span class="absolute inset-x-0 -bottom-1 h-[2px] transition-transform duration-300 origin-left <%= isHome ? 'bg-axolotl-pink-500 scale-x-100' : 'bg-slate-950 scale-x-0 group-hover:scale-x-100' %>"></span>
        </a>
        <a href="/docs" class="relative px-1 py-2 text-sm font-medium transition-colors group <%= isDocs ? 'text-axolotl-pink-500' : 'text-slate-600 hover:text-slate-950' %>">
          Docs
          <span class="absolute inset-x-0 -bottom-1 h-[2px] transition-transform duration-300 origin-left <%= isDocs ? 'bg-axolotl-pink-500 scale-x-100' : 'bg-slate-950 scale-x-0 group-hover:scale-x-100' %>"></span>
        </a>
        <a href="/mock" class="relative px-1 py-2 text-sm font-medium transition-colors group <%= isMock ? 'text-axolotl-pink-500' : 'text-slate-600 hover:text-slate-950' %>">
          Mock Builder
          <span class="absolute inset-x-0 -bottom-1 h-[2px] transition-transform duration-300 origin-left <%= isMock ? 'bg-axolotl-pink-500 scale-x-100' : 'bg-slate-950 scale-x-0 group-hover:scale-x-100' %>"></span>
        </a>
        <a href="https://github.com/fauzantaslim/AxoMock" target="_blank" rel="noopener" class="relative px-1 py-2 text-sm font-medium text-slate-600 hover:text-slate-950 transition-colors group">
          GitHub
          <span class="absolute inset-x-0 -bottom-1 h-[2px] bg-slate-950 transition-transform duration-300 origin-left scale-x-0 group-hover:scale-x-100"></span>
        </a>
      </nav>

      <!-- Mobile Menu Button -->
      <div class="flex items-center md:hidden">
        <button 
          @click="mobileMenuOpen = !mobileMenuOpen" 
          type="button" 
          class="text-slate-500 hover:text-slate-700 focus:outline-none p-2"
          aria-controls="mobile-menu" 
          :aria-expanded="mobileMenuOpen"
        >
          <span class="sr-only">Open main menu</span>
          <svg x-show="!mobileMenuOpen" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
          <svg x-show="mobileMenuOpen" x-cloak class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div 
    x-show="mobileMenuOpen" 
    x-collapse 
    x-cloak
    id="mobile-menu" 
    class="md:hidden border-t border-slate-200 bg-white"
  >
    <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
      <a href="/" class="block px-3 py-2 rounded-md text-base font-medium <%= isHome ? 'bg-axolotl-pink-50 text-axolotl-pink-500' : 'text-slate-700 hover:bg-slate-50 hover:text-slate-900' %>">
        Home
      </a>
      <a href="/docs" class="block px-3 py-2 rounded-md text-base font-medium <%= isDocs ? 'bg-axolotl-pink-50 text-axolotl-pink-500' : 'text-slate-700 hover:bg-slate-50 hover:text-slate-900' %>">
        Docs
      </a>
      <a href="/mock" class="block px-3 py-2 rounded-md text-base font-medium <%= isMock ? 'bg-axolotl-pink-50 text-axolotl-pink-500' : 'text-slate-700 hover:bg-slate-50 hover:text-slate-900' %>">
        Mock Builder
      </a>
      <a href="https://github.com/fauzantaslim/AxoMock" target="_blank" rel="noopener" class="block px-3 py-2 rounded-md text-base font-medium text-slate-700 hover:bg-slate-50 hover:text-slate-900">
        GitHub
      </a>
    </div>
  </div>
</header>
